<div class="bg-gray-800 border border-gray-700 rounded-lg p-4"
     data-controller="progress"
     data-progress-download-id-value="<%= download.id %>"
     id="download-<%= download.id %>">

  <div class="flex justify-between items-center mb-2">
    <div>
      <span class="font-medium" data-progress-target="title"><%= download.title || "Loading..." %></span>
      <span class="text-xs text-gray-500 ml-2" data-progress-target="status"><%= download.status.humanize %></span>
    </div>
    <%= button_to "Cancel", download_path(download), method: :delete,
        class: "text-xs text-red-400 hover:text-red-300",
        data: { turbo_confirm: "Cancel this download?" } %>
  </div>

  <div class="w-full bg-gray-700 rounded-full h-3 mb-2">
    <div class="bg-indigo-500 h-3 rounded-full transition-all duration-300"
         data-progress-target="bar"
         style="width: 0%"></div>
  </div>
  <span class="text-xs text-gray-400" data-progress-target="text">0%</span>

  <details class="mt-3" data-controller="log-panel" data-log-panel-download-id-value="<%= download.id %>">
    <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-300">Logs</summary>
    <div class="mt-2 max-h-48 overflow-y-auto bg-gray-900 rounded p-2 text-xs font-mono" data-log-panel-target="container">
      <% download.download_logs.order(:created_at).each do |log| %>
        <div class="<%= log.error? ? 'text-red-400' : log.warn? ? 'text-yellow-400' : 'text-gray-400' %>">
          <%= log.message %>
        </div>
      <% end %>
    </div>
  </details>
</div>
