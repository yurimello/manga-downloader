<div class="bg-gray-800 border border-gray-700 rounded-lg p-4" id="download-<%= download.id %>">
  <div class="flex justify-between items-center">
    <div class="flex items-center gap-2">
      <% if download.completed? %>
        <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
      <% else %>
        <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
      <% end %>
      <span class="font-medium"><%= download.title || download.url %></span>
      <span class="text-xs text-gray-500"><%= download.completed_at&.strftime("%Y-%m-%d %H:%M") %></span>
    </div>
    <div class="flex gap-3">
      <%= button_to "Reprocess", reprocess_download_path(download), method: :post,
          class: "text-xs text-indigo-400 hover:text-indigo-300" %>
      <%= button_to "Remove", download_path(download), method: :delete,
          class: "text-xs text-gray-500 hover:text-gray-300" %>
    </div>
  </div>

  <% if download.error_message.present? %>
    <p class="text-xs text-red-400 mt-1"><%= download.error_message %></p>
  <% end %>

  <details class="mt-3">
    <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-300">Logs</summary>
    <div class="mt-2 max-h-48 overflow-y-auto bg-gray-900 rounded p-2 text-xs font-mono">
      <% download.download_logs.order(:created_at).each do |log| %>
        <div class="<%= log.error? ? 'text-red-400' : log.warn? ? 'text-yellow-400' : 'text-gray-400' %>">
          <%= log.message %>
        </div>
      <% end %>
    </div>
  </details>
</div>
